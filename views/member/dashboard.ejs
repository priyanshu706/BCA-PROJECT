<%- include('../partials/header') %>

<section class="page-head">
  <div>
    <h1 class="page-title">My Blogs</h1>
    <p class="muted"><%= counts.all %> total · <%= counts.published %> published · <%= counts.draft %> draft · <%= counts.trash %> trash</p>
  </div>
  <div class="head-actions">
    <a href="/blogs/generate" class="btn"><i class="fa-solid fa-wand-magic-sparkles"></i> Generate with AI</a>
    <a href="/blogs/write" class="btn btn-ghost"><i class="fa-solid fa-pen-nib"></i> Write Manually</a>
  </div>
</section>

<!-- Status filter tabs -->
<div class="filter-tabs">
  <a href="/dashboard?status=all" class="filter-tab <%= statusFilter === 'all' ? 'active' : '' %>">All (<%= counts.all %>)</a>
  <a href="/dashboard?status=published" class="filter-tab <%= statusFilter === 'published' ? 'active' : '' %>">Published (<%= counts.published %>)</a>
  <a href="/dashboard?status=draft" class="filter-tab <%= statusFilter === 'draft' ? 'active' : '' %>">Drafts (<%= counts.draft %>)</a>
  <a href="/dashboard?status=trash" class="filter-tab <%= statusFilter === 'trash' ? 'active' : '' %>">Trash (<%= counts.trash %>)</a>
</div>

<% if (!blogs.length) { %>
  <div class="empty-state">
    <div class="empty-icon"><i class="fa-regular fa-pen-to-square"></i></div>
    <h3>No blogs here</h3>
    <p>Generate one with AI or write your own to get started.</p>
  </div>
<% } else { %>
  <table class="data-table">
    <thead><tr><th>Title</th><th>Category</th><th>Source</th><th>Status</th><th>Views</th><th>Actions</th></tr></thead>
    <tbody>
      <% blogs.forEach(function(blog){ %>
        <tr>
          <td><a href="/blog/<%= blog.slug %>"><%= blog.title %></a></td>
          <td><%= blog.category ? blog.category.name : '—' %></td>
          <td><%= blog.source === 'ai' ? 'AI' : 'Manual' %></td>
          <td><span class="status status-<%= blog.status %>"><%= blog.status %></span></td>
          <td><%= blog.views %></td>
          <td class="row-actions">
            <% if (blog.status === 'trash') { %>
              <form action="/blogs/<%= blog._id %>/status" method="POST" class="inline-form">
                <input type="hidden" name="status" value="draft" />
                <button type="submit" class="link-btn">Restore</button>
              </form>
              <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST" class="inline-form"
                    onsubmit="return confirm('Delete this blog permanently?');">
                <button type="submit" class="link-btn link-danger">Delete Forever</button>
              </form>
            <% } else { %>
              <a href="/blogs/<%= blog._id %>/edit" class="link-btn">Edit</a>
              <% if (blog.status === 'draft') { %>
                <form action="/blogs/<%= blog._id %>/status" method="POST" class="inline-form">
                  <input type="hidden" name="status" value="published" />
                  <button type="submit" class="link-btn">Publish</button>
                </form>
              <% } else { %>
                <form action="/blogs/<%= blog._id %>/status" method="POST" class="inline-form">
                  <input type="hidden" name="status" value="draft" />
                  <button type="submit" class="link-btn">Unpublish</button>
                </form>
              <% } %>
              <form action="/blogs/<%= blog._id %>/status" method="POST" class="inline-form">
                <input type="hidden" name="status" value="trash" />
                <button type="submit" class="link-btn link-danger">Trash</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
