# ============================================================
#  AI-Powered Blog Platform — Environment Variables
#  Copy this file to ".env" and fill in your own values.
# ============================================================

# Port the server listens on
PORT=3000

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/ai_blog_platform
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai_blog_platform
MONGODB_URI=mongodb://127.0.0.1:27017/ai_blog_platform

# Secret used to sign session cookies (use a long random string)
SESSION_SECRET=change_this_to_a_long_random_secret_string

# --- Default AI / image keys ---------------------------------
# These act as the DEFAULT keys. An administrator can override
# them at run time from the Admin > Settings page (stored in DB).
# Get a free Groq key:  https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Image provider: "pexels" or "pixabay"
IMAGE_PROVIDER=pexels
# Pexels:  https://www.pexels.com/api/   |  Pixabay: https://pixabay.com/api/docs/
IMAGE_API_KEY=your_image_api_key_here

# --- Bootstrap administrator ---------------------------------
# On first start, if no admin exists, one is created from these
# values. This is the initial (hard-coded) admin; once logged in
# it can create additional administrators from the Admin panel.
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@blogplatform.local
ADMIN_PASSWORD=Admin@12345

NODE_ENV=development
